---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('tutorials')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const latestPost = posts[0];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				text-align: center;
				padding: 4rem 0;
			}
			.subtitle {
				font-size: 1.25rem;
				color: var(--text-muted);
				max-width: 600px;
				margin: 0 auto;
			}
			.cta-buttons {
				margin-top: 2rem;
				display: flex;
				justify-content: center;
				gap: 1rem;
			}
			.btn-primary {
				background: var(--accent-gradient);
				color: white;
				padding: 0.8rem 1.5rem;
				border-radius: 8px;
				font-weight: 600;
				font-family: 'Outfit', sans-serif;
				transition: transform 0.2s, box-shadow 0.2s;
			}
			.btn-primary:hover {
				transform: translateY(-2px);
				box-shadow: 0 4px 15px var(--accent-glow);
				color: white;
			}
			.btn-secondary {
				background: var(--surface-color);
				border: 1px solid var(--glass-border);
				color: var(--text-main);
				padding: 0.8rem 1.5rem;
				border-radius: 8px;
				font-weight: 500;
			}
			.btn-secondary:hover {
				background: var(--glass-bg);
			}
			.latest-tutorial {
				margin-top: 4rem;
			}
			.latest-tutorial h3 {
				text-align: center;
				font-size: 1.5rem;
				color: var(--text-muted);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Run AI on the Edge.</h1>
				<p class="subtitle">
					Learn how to deploy classical computer vision algorithms and deep learning models directly in the browser, achieving zero-server-cost inference and maximum privacy.
				</p>
				<div class="cta-buttons">
					<a href={`${import.meta.env.BASE_URL}/tutorials`} class="btn-primary">Browse Tutorials</a>
					{latestPost && <a href={`${import.meta.env.BASE_URL}tutorials/${latestPost.id}`} class="btn-secondary">Read Latest</a>}
				</div>
			</section>

			{latestPost && (
				<section class="latest-tutorial">
					<h3>Featured Tutorial</h3>
					<div class="glass-panel">
						<h2><a href={`${import.meta.env.BASE_URL}/tutorials/${latestPost.id}`}>{latestPost.data.title}</a></h2>
						<p>{latestPost.data.description}</p>
					</div>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>
